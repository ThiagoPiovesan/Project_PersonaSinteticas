# ============================================
# Galaxies — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.
# NÃO comite o .env no repositório.

# --- OpenAI ---
OPENAI_API_KEY=""

# --- Modelo LLM ---
# Opções: gpt-4o-mini (custo), gpt-4o (qualidade)
LLM_MODEL=gpt-4o-mini

# --- Temperatura do LLM ---
# 0.0 = determinístico, 1.0 = criativo
LLM_TEMPERATURE=0.7

# --- Tokens máximos por resposta ---
LLM_MAX_TOKENS=1024
